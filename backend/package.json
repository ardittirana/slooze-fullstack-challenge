{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS + GraphQL + Prisma API for the Slooze food ordering challenge",
  "scripts": {
    "postinstall": "prisma generate",
    "setup": "prisma migrate deploy && prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.2",
    "@nestjs/apollo": "^12.2.0",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/graphql": "^12.2.0",
    "@nestjs/platform-express": "^10.4.4",
    "@prisma/client": "^5.22.0",
    "graphql": "^16.9.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
